<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="424.0" prefWidth="672.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.eventsystemassignment.gui.AdminPageController">
   <children>
      <TableView fx:id="tblUsers" layoutX="14.0" layoutY="90.0" prefHeight="226.0" prefWidth="661.0">
        <columns>
          <TableColumn fx:id="usernameColumn" prefWidth="128.5" text="Username" />
            <TableColumn fx:id="usertypeColumn" prefWidth="158.0" text="Usertype" />
            <TableColumn fx:id="firstnameColumn" prefWidth="168.5" text="First name" />
            <TableColumn fx:id="lastnameColumn" prefWidth="205.0" text="Last name" />
        </columns>
      </TableView>
      <TableView fx:id="tblEvents" layoutX="15.0" layoutY="90.0" prefHeight="226.0" prefWidth="661.0" visible="false">
         <columns>
            <TableColumn fx:id="eventnameColumn" prefWidth="77.5" text="Eventname" />
            <TableColumn fx:id="starttimeColumn" prefWidth="64.5" text="Starttime" />
            <TableColumn fx:id="startdateColumn" prefWidth="69.5" text="Startdate" />
            <TableColumn fx:id="locationColumn" prefWidth="87.0" text="Location" />
            <TableColumn fx:id="extranotesColumn" prefWidth="96.0" text="Extra notes" />
            <TableColumn fx:id="endtimeColumn" prefWidth="56.5" text="End time" />
            <TableColumn fx:id="enddateColumn" prefWidth="75.0" text="End date" />
            <TableColumn fx:id="locationguidanceColumn" prefWidth="134.0" text="Location guidance" />
         </columns>
      </TableView>
      <Button fx:id="btnDeleteEvent" layoutX="11.0" layoutY="328.0" mnemonicParsing="false" onAction="#onDeleteEvent" text="Delete event" visible="false" />
      <Button fx:id="btnAssignCoordinator" layoutX="132.0" layoutY="328.0" mnemonicParsing="false" onAction="#onAssignCoordinator" text="Assign Coordinators" visible="false" />
      <Text layoutX="12.0" layoutY="23.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Admin page" />
      <Line endX="654.0" layoutX="113.0" layoutY="38.0" startX="-113.0" />
      <Button fx:id="btnCreateUser" layoutX="15.0" layoutY="328.0" mnemonicParsing="false" onAction="#onCreateUser" text="Create user" />
      <Button fx:id="btnDeleteUser" layoutX="132.0" layoutY="328.0" mnemonicParsing="false" onAction="#btnOnDeleteUser" text="Delete User" />
      <Button layoutX="543.0" layoutY="6.0" mnemonicParsing="false" onAction="#onGoBackToMainPage" text="Go back to main page" />
      <ChoiceBox fx:id="cbTableType" layoutX="15.0" layoutY="51.0" prefWidth="150.0" />
      <Button fx:id="btnRefreshPage" layoutX="431.0" layoutY="6.0" mnemonicParsing="false" onAction="#onRefreshPage" text="Refresh page" />
   </children>
